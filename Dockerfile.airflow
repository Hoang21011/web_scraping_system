FROM apache/airflow:2.10.4-python3.12
USER root
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*
# Tải trực tiếp Docker CLI bản mới nhất (27.0.3) để tương thích với API của Docker Desktop trên Mac (1.44+)
RUN curl -fsSL "https://download.docker.com/linux/static/stable/$(uname -m)/docker-27.0.3.tgz" -o docker.tgz \
    && tar -xzf docker.tgz \
    && mv docker/docker /usr/bin/docker \
    && rm -rf docker docker.tgz
USER airflow
